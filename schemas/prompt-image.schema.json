{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/24kchengYe/prompt-harness/schemas/prompt-image.schema.json",
  "title": "Prompt Harness user image attachment",
  "type": "object",
  "required": ["schema_version", "record_type", "attachment_id", "event_id", "captured_at", "asset", "source"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "prompt_image"},
    "attachment_id": {"type": "string", "pattern": "^phi_[0-9a-f]{32}$"},
    "event_id": {"type": "string", "pattern": "^phe_[0-9a-f]{32}$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "asset": {
      "type": "object",
      "required": ["path", "sha256", "bytes", "media_type"],
      "properties": {
        "path": {"type": "string", "pattern": "^assets/images/[0-9a-f]{64}\\.(png|jpg|gif|webp|bmp)$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": "integer", "minimum": 1},
        "media_type": {"enum": ["image/png", "image/jpeg", "image/gif", "image/webp", "image/bmp"]}
      }
    },
    "source": {
      "type": "object",
      "required": ["kind", "original_name", "transcript_path", "line"],
      "properties": {
        "kind": {"enum": ["local_path", "data_url", "base64"]},
        "original_name": {"type": ["string", "null"]},
        "transcript_path": {"type": ["string", "null"]},
        "line": {"type": ["integer", "null"], "minimum": 1}
      }
    }
  }
}
