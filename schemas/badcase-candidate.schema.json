{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/24kchengYe/prompt-harness/schemas/badcase-candidate.schema.json",
  "title": "Prompt Harness badcase review candidate",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "candidate_id",
    "detected_at",
    "fingerprint",
    "detector",
    "project",
    "session",
    "source_prompt_event_id",
    "evidence",
    "proposal"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "record_type": {"const": "badcase_candidate"},
    "candidate_id": {"type": "string", "pattern": "^bcc_[0-9a-f]{32}$"},
    "detected_at": {"type": "string", "format": "date-time"},
    "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "detector": {
      "type": "object",
      "required": ["name", "version", "score", "signals", "asserts_failure"],
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "asserts_failure": {"const": false}
      }
    },
    "project": {"type": "object"},
    "session": {"type": "object"},
    "source_prompt_event_id": {"type": "string", "pattern": "^phe_[0-9a-f]{32}$"},
    "evidence": {
      "type": "object",
      "required": ["prompt_event_ids", "trace_event_ids", "trace_event_count", "from", "to"]
    },
    "proposal": {"type": "object"}
  }
}
